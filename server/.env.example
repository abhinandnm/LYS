# LYS Backend Configuration (Environment Variables)

# Node Server
PORT=3001

# AWS Credentials (IAM Role or User Keys)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# AWS S3 (Storage Service)
S3_BUCKET_NAME=lys-service-images

# AWS RDS (Database Service - PostgreSQL)
DB_HOST=your-rds-endpoint.amazonaws.com
DB_USER=lys_admin
DB_PASSWORD=lys_p@ssword123
DB_NAME=lys_db
